{
  "manifest_version": 3,
  "name": "Comparador de Preços",
  "description": "Compara preços do produto atual nas principais lojas brasileiras e internacionais.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Comparador de Preços"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://api.mercadolibre.com/*",
    "https://www.amazon.com.br/*",
    "https://shopee.com.br/*",
    "https://www.magazineluiza.com.br/*",
    "https://www.casasbahia.com.br/*",
    "https://www.aliexpress.com/*"
  ]
}
